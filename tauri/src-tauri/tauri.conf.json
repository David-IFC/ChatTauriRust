{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chat PWA",
  "version": "1.0.0",
  "identifier": "com.chatrusttauri.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chat PWA",
        "url": "https://chatrusttauri.xo.je",
        "width": 420,
        "height": 760,
        "minWidth": 360,
        "minHeight": 540,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
